  speakerType: 0
  speakerName: "T\u1ED5ng \u0110\u1EA1o Di\u1EC5n"
  text: "Anh c\u0169ng \u0111ang \u0111i\xEAn \u0111\u1EA7u \u0111\xE2y. Em nh\xECn
